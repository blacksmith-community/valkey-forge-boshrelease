---
name: standalone
packages:
  - valkey-7
  - valkey-8
  - valkey-9
templates:
  bin/pre-start: bin/pre-start
  config/bpm.yml: config/bpm.yml
  config/tls/valkey.ca: config/tls/valkey.ca
  config/tls/valkey.ca_cert: config/tls/valkey.cert
  config/tls/valkey.ca_key: config/tls/valkey.key
  config/req.conf.erb: config/req.conf
  config/valkey.conf: config/valkey.conf
  dns/aliases.json.erb: dns/aliases.json

properties:
  service.type:
    default: "standalone"

  valkey.version:
    description: "Major version of Valkey to run (7, 8, or 9)"
    default: 8

  auth.password:
    description: The password required of clients wishing to use this Valkey instance.

  persistent:
    description: Whether or not the Valkey dataset should persist to disk (via AOF semantics)
    default: true

  lua.scripting-enabled:
    description: Whether or not to allow lua scripting.
    default: true

  client.connections:
    description: Set the max number of connected clients at the same time
    default: 10000

  client.timeout:
    description: Close the connection after a client is idle for N seconds (0 to disable)
    default: 0

  client.tcpkeepalive:
    description: If non-zero, use SO_KEEPALIVE to send TCP ACKs to clients in absence of communication
    default: 300

  valkey.tls.enabled:
    description: "Should the Valkey use TLS"
    default: false
  valkey.tls.dual-mode:
    description: "Allow for TLS (16379) and Non-TLS (6379) both."
    default: false
  valkey.tls.ca:
    description: The PEM-encoded certificate of the CA that signed the Valkey Certificate.
  valkey.tls.ca_cert:
    description: The PEM-encoded certificate of the CA cert that signed the Valkey Certificate.
  valkey.tls.ca_key:
    description: The PEM-encoded certificate of the Valkey itself.

  valkey.maxmemory:
    description: |
       Set a memory usage limit to the specified amount of bytes.
       Memory units may be specified when specifying bytes.
       1k => 1000 bytes
       1kb => 1024 bytes
       1m => 1000000 bytes
       1mb => 1024*1024 bytes
       1g => 1000000000 bytes
       1gb => 1024*1024*1024 bytes
       units are case insensitive so 1GB 1Gb 1gB are all the same.

    default: 0

  valkey.maxmemory-policy:
    description: |
      Sets the behavior Valkey follows when maxmemory is reached.
      allkeys-lru, noeviction, volatile-lru,
      allkeys-random, volatile-ttl, volatile-lfu, allkeys-lfu

    default: "allkeys-lru"

  valkey.notify-keyspace-events:
    description: |
      Sets the keyspace notifications for events that
      affect the Valkey data set

    default: ""

  valkey.slowlog-log-slower-than:
    description: |
      Sets the threshhold execution time (seconds).
      Commands that exceed this execution time are added
      to the slowlog.

    default: 10000

  valkey.slowlog-max-len:
    description: Sets the length (count) of the slowlog queue.
    default: 128

  valkey.no-appendfsync-on-rewrite:
    description: If you have latency problems turn this to true. Otherwise leave it as false
    default: false

  valkey.auto-aof-rewrite-percentage:
    description: Modify the percentage for auto append on rewrite.
    default: 100

  valkey.auto-aof-rewrite-min-size:
    description: Modify the minimum file size  for auto append on rewrite.
    default: "64mb"

  valkey.disabled-commands:
    description: |
      Disable Valkey commands, to enable or disable LUA scripting commands
      use the configuration `lua.scripting-enabled` instead.
    default: ["CONFIG", "SAVE", "BGSAVE", "DEBUG", "SHUTDOWN", "SLAVEOF", "SYNC"]
