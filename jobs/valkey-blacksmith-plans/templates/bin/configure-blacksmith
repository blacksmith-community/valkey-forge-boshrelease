#!/bin/bash

set -eux

plan_src="/var/vcap/jobs/valkey-blacksmith-plans/plans"
svc_root="/var/vcap/data/blacksmith/valkey-forge/services"

rm -rf "${svc_root}" ; mkdir -p "${svc_root}"

cp "${plan_src}/service.yml" "${svc_root}" # Copy the service definition stub for Blacksmith

<% p('plans').each do |id, plan| %>
################################################################################
echo -e "Setting plan: <%= id %>"
################################################################################
plan_id="<%= id %>"
plan_name="<%= plan['name'] || id %>"
plan_limit="<%= plan['limit'] || 0 %>"
plan_root="${svc_root}/<%= id %>"
plan_type="<%= plan['type'] || 'standalone' %>"
plan_description="<%= plan['description'] || 'no description provided' %>"

mkdir -p "${plan_root}"

cat > "${plan_root}/plan.yml" <<EOF
---
id: "${plan_id}"
name: "${plan_name}"
limit: ${plan_limit}
type: <%= if plan["type"].include?("standalone")
            "standalone"
          elsif plan["type"].include?("cluster")
            "node"
          else
            plan["type"]
          end %>
description: |+
  "${plan_description}"
EOF

for file in init credentials.yml manifest.yml
do
  echo "Copying ${plan_src}/${plan_type}/${file} to ${plan_root}/"
  cp "${plan_src}/${plan_type}/${file}" "${plan_root}"/
done

chmod 0755 "${plan_root}/init"

cat > "${plan_root}/params.yml" <<EOF
---
# auto-generated by valkey-blacksmith-plans
# for plan-id <%= id %> (<%= plan["name"] || id %>)
meta:
  size: <%= plan["vm_type"] || 'default' %>
  net:  <%= plan["network"] || 'valkey-service' %>

<% if plan["valkey_maxmemory-policy"] -%>
  valkey_maxmemory-policy: <%= plan["valkey_maxmemory-policy"] %>
<% end -%>

<% if p('valkey.tls.enabled') -%>
  valkey:
    tls:
      enabled: true
<% if_p('valkey.tls.ca') do -%>
      ca: (( file "/var/vcap/jobs/valkey-blacksmith-plans/config/tls/valkey.ca" ))
<% end -%>
<% if_p('valkey.tls.ca_cert') do -%>
      ca_cert: (( file "/var/vcap/jobs/valkey-blacksmith-plans/config/tls/valkey.cert" ))
<% end -%>
<% if_p('valkey.tls.ca_key') do -%>
      ca_key: (( file "/var/vcap/jobs/valkey-blacksmith-plans/config/tls/valkey.key" ))
<% end -%>
<% if p('valkey.tls.dual-mode') -%>
      dual-mode: true
<% end -%>
<% end -%>

<% if plan["valkey_maxmemory"] -%>
  valkey_maxmemory: <%= plan["valkey_maxmemory"] %>
<% end -%>

<% if plan["valkey_notify-keyspace-events"] -%>
  valkey_notify-keyspace-events: <%= plan["valkey_notify-keyspace-events"] %>
<% end -%>

<% if plan["valkey_slowlog-log-slower-than"] -%>
  valkey_slowlog-log-slower-than: <%= plan["valkey_slowlog-log-slower-than"] %>
<% end -%>

<% if plan["valkey_slowlog-max-len"] -%>
  valkey_slowlog-max-len: <%= plan["valkey_slowlog-max-len"] %>
<% end -%>

<% if plan.has_key?("valkey_no-appendfsync-on-rewrite") -%>
  valkey_no-appendfsync-on-rewrite: <%= plan["valkey_no-appendfsync-on-rewrite"] ? "yes" : "no" %>
<% end -%>

<% if plan["valkey_auto-aof-rewrite-percentage"] -%>
  valkey_auto-aof-rewrite-percentage: <%= plan["valkey_auto-aof-rewrite-percentage"] %>
<% end -%>

<% if plan["valkey_auto-aof-rewrite-min-size"] -%>
  valkey_auto-aof-rewrite-min-size: <%= plan["valkey_auto-aof-rewrite-min-size"] %>
<% end -%>

<% if plan["client_timeout"] -%>
  client_timeout: <%= plan["client_timeout"] %>
<% end -%>

<% if plan["client_tcpkeepalive"] -%>
  client_tcpkeepalive: <%= plan["client_tcpkeepalive"] %>
<% end -%>

<% if plan["client_connections"] -%>
  client_connections: <%= plan["client_connections"] %>
<% end -%>

<% if plan.has_key?("lua_scripting_enabled") -%>
  lua_scripting_enabled: <%= plan["lua_scripting_enabled"] %>
<% end -%>

<% if plan["azs"] -%>
  azs: <%= plan["azs"] %>
<% end -%>

<% if plan["type"] =~ /standalone/ -%>
<%   if plan["persist"] -%>
  persistent: true
<%     if plan["disk_type"] -%>
  disk_config: { persistent_disk_type: <%= plan["disk_type"] %> }
<%     else -%>
  disk_config: { persistent_disk: <%= plan["disk_size"] || 1_024 %> }
<%     end -%>
<%   else -%>
  persistent: false
<%   end -%>
<% end -%>

<% if plan["type"] =~ /cluster/ && plan['masters'] && plan['masters'] > 0 -%>
  masters:   <%= plan['masters'] %>
  replicas:  <%= plan['replicas'] || 1 %>
  instances: <%= plan['masters'] + plan['masters'] * (plan['replicas'] || 1) %>
<% end -%>

<% if plan["exporter"] -%>
releases:
- name:    "prometheus"
  version: "<%= plan["prometheus_release_version"] || "30.2.0" %>"
  url:     "<%= plan["prometheus_release_url"] || "https://bosh.io/d/github.com/cloudfoundry-community/prometheus-boshrelease?v=30.2.0" %>"
  sha1:    "<%= plan["prometheus_release_sha1"] || "0ba6f3eae9071fb554082398997d57a742c3fe3c" %>"

instance_groups:
- name: <%= plan["type"] =~ /standalone/ ? "standalone" : "node" %>
  jobs:
  - name: valkey_exporter
    release: prometheus
    properties:
      valkey_exporter:
        valkey:
          password: (( grab meta.password ))
<% end -%>
EOF
<% end -%>
