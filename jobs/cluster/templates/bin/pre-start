#!/bin/bash

export JOB_DIR=/var/vcap/jobs/cluster
export DATA_DIR=/var/vcap/data/cluster
export PATH="/var/vcap/packages/valkey-<%= p('valkey.version') %>/bin:$PATH"

openssl req -new -nodes -days 730 -newkey rsa:2048 -keyout $DATA_DIR/valkey.key -out $DATA_DIR/valkey.csr -config $JOB_DIR/config/req.conf -extensions 'v3_req'

openssl x509 -req -in $DATA_DIR/valkey.csr -CA $JOB_DIR/config/tls/valkey.cert -CAkey $JOB_DIR/config/tls/valkey.key -CAcreateserial -out $DATA_DIR/valkey.crt -days 825 -sha256

cp $JOB_DIR/config/tls/valkey.ca /usr/local/share/ca-certificates/valkey.crt
update-ca-certificates

chown vcap:vcap $DATA_DIR/*

# System configuration for Valkey
sysctl vm.overcommit_memory=1
echo never > /sys/kernel/mm/transparent_hugepage/enabled || true

# Create Valkey version files
mkdir -p /var/vcap/store/cluster

# Initialize ACL file if empty/missing (aclfile overrides requirepass, so the
# default user must be defined here). On subsequent boots the file already
# contains per-binding users from ACL SAVE, so only seed on first run.
ACL_FILE=/var/vcap/store/cluster/users.acl
if [ ! -s "$ACL_FILE" ]; then
  PASS=$(grep requirepass $JOB_DIR/config/valkey.conf | awk '{print $2}')
  echo "user default on >${PASS} sanitize-payload ~* &* +@all" > "$ACL_FILE"
  chown vcap:vcap "$ACL_FILE"
fi
chpst -u vcap:vcap valkey-server --version > /var/vcap/store/cluster/VALKEY_VERSION_FULL
chpst -u vcap:vcap valkey-server --version | sed -e 's/.* v=\([^ ]*\).*/\1/' > /var/vcap/store/cluster/VALKEY_VERSION
chown vcap:vcap /var/vcap/store/cluster/VALKEY_VERSION_FULL /var/vcap/store/cluster/VALKEY_VERSION
